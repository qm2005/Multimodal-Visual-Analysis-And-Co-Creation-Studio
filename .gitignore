# 依赖包 (最占用空间，绝对不能上传)
node_modules/
/jspm_packages/
/.pnp
.pnp.js

# 编译输出 (自动生成的代码，不需要上传)
dist/
dist-ssr/
build/
*.local

# 环境变量 (非常重要！防止 Gemini API Key 泄露)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# 排除环境示例文件 (这个可以上传，作为给别人的模板)
!.env.example

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# 编辑器与系统文件
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 单元测试
/coverage/

# TypeScript 缓存
*.tsbuildinfo